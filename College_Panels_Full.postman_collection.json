            "method": "GET",
            "url": "{{baseUrl}}/students/verify-college?code={{collegeCode}}"
          }
        },
        {
          "name": "2. Get Branches by College Code (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/students/branches?code={{collegeCode}}"
          }
        },
        {
          "name": "3. Register (Public)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/students/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Student\",\n  \"email\": \"student@example.com\",\n  \"mobile\": \"9876543210\",\n  \"password\": \"password123\",\n  \"collegeCode\": \"{{collegeCode}}\",\n  \"branchId\": \"{{branchId}}\"\n}"
            }
