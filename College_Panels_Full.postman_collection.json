  "item": [
    {
      "name": "Super Admin",
      "item": [
        {
          "name": "1. Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/super-admin/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Name\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "2. Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/super-admin/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "3. Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/super-admin/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "4. Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/super-admin/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Name" },
                { "key": "phone", "value": "9876543210" },
                { "key": "profileImage", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "5. Change Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/super-admin/change-password",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "6. Get Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/super-admin/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "7. Get College Stats (SuperAdmin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/super-admin/colleges/{{collegeId}}/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
